# SMTP
# Docker Compose defaults to Mailhog (mailhog:1025, auth disabled).
# Override these values for Outlook/Microsoft 365 or another real SMTP server.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_USER=your_email@outlook.com
SMTP_PASS=your_app_password_or_smtp_password
SMTP_FROM=your_email@outlook.com

# Reminder behavior
REMINDER_HOURS_BEFORE=3
